# API Configuration
# Choose ONE of the following options:

# Option 1: Local Backend (for development with local server)
# EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:3000/api

# Option 2: Production Backend (requires CORS configuration on backend)
# EXPO_PUBLIC_API_URL=https://vetician-backend-kovk.onrender.com/api

# Option 3: Localhost (only works in web browser, not on mobile devices)
# EXPO_PUBLIC_API_URL=http://localhost:3000/api
